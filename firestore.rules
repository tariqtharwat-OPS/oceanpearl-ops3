rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() { return request.auth != null; }
    function uid() { return request.auth.uid; }

    function userDoc() {
      return get(/databases/$(database)/documents/v3_users/$(uid())).data;
    }

    function role() {
      return isAuthenticated() ? userDoc().role : null;
    }

    // Role Normalization Helper
    function normalizedRole() {
      return role() != null ? role().lower() : "";
    }

    // Canonical Checks (Case-Insensitive)
    function isAdmin() { 
      return normalizedRole() == "admin"; 
    }
    function isCEO() { 
      return normalizedRole() == "ceo"; 
    }
    function isUnitOperator() { 
      return normalizedRole() == "unit_operator" || normalizedRole() == "operator"; // Compat with old OPERATOR
    }
    function isFinance() { 
      return normalizedRole() == "finance_officer" || normalizedRole() == "hq_finance"; 
    }
    function isLocationManager() {
      return normalizedRole() == "location_manager";
    }

    // -------------------------
    // User Profiles (v3_users)
    // -------------------------
    match /v3_users/{userId} {
      allow read: if isAuthenticated() && (
        userId == uid() || 
        isAdmin() || 
        isCEO() || 
        isFinance() ||
        isLocationManager() // Managers need to see profiles sometimes
      );
      // Only Admin/CEO can create/update profiles (provisioning)
      allow write: if isAuthenticated() && (isAdmin() || isCEO()); 
    }

    // -------------------------
    // Public metadata (optional)
    // -------------------------
    match /v3_locations/{locationId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (isAdmin() || isCEO());
    }

    match /v3_units/{unitId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (isAdmin() || isCEO());
    }
    match /v3_partners/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (isAdmin() || isCEO());
    }
    match /v3_species/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (isAdmin() || isCEO());
    }
    match /v3_products/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (isAdmin() || isCEO());
    }
    match /v3_system/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (isAdmin() || isCEO());
    }
    match /v3_seed_packs/{id} {
      allow read: if isAuthenticated() && (isAdmin() || isCEO());
    }

    // -------------------------
    // Core operational / financial collections (SERVER ONLY)
    // Clients MUST NOT read/write directly. Access via Cloud Functions.
    // -------------------------
    match /v3_ledger_entries/{docId} {
      allow read, write: if false;
    }
    match /v3_inventory_valuations/{docId} {
      allow read, write: if false;
    }
    match /v3_trace_events/{docId} {
      allow read, write: if false;
    }
    match /v3_batches/{docId} {
      allow read, write: if false;
    }
    match /v3_shark_alerts/{docId} {
      allow read, write: if false;
    }
    match /v3_shark_location_risk/{docId} {
      allow read, write: if false;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
