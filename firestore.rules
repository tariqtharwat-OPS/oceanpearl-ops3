rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuth() {
      return request.auth != null && request.auth.uid != null;
    }
    
    function matchesScope(data) {
      return (data.company_id == request.auth.token.company_id)
          && (data.location_id == request.auth.token.location_id)
          && (data.unit_id == request.auth.token.unit_id);
    }

    match /users/{userId} {
      allow read: if isAuth() && request.auth.uid == userId;
      allow write: if false; 
    }

    match /locations/{locationId} {
      allow read: if isAuth() && resource.data.location_id == request.auth.token.location_id;
      allow write: if false;
    }

    match /units/{unitId} {
      allow read: if isAuth() && resource.data.unit_id == request.auth.token.unit_id;
      allow write: if false;
    }

    // Inbox collections for offline sync
    match /wallet_event_requests/{requestId} {
      allow create: if isAuth() && matchesScope(request.resource.data);
      allow read, update, delete: if false;
    }

    match /inventory_event_requests/{requestId} {
      allow create: if isAuth() && matchesScope(request.resource.data);
      allow read, update, delete: if false;
    }

    // Ledger collections (written by Cloud Functions only)
    match /wallet_events/{eventId} {
      allow read: if isAuth() && matchesScope(resource.data);
      allow write: if false; 
    }

    match /wallet_states/{stateId} {
      allow read: if isAuth();
      allow write: if false; 
    }

    match /inventory_events/{eventId} {
      allow read: if isAuth() && matchesScope(resource.data);
      allow write: if false; 
    }

    match /inventory_states/{stateId} {
      allow read: if isAuth();
      allow write: if false; 
    }

    match /idempotency_locks/{lockId} {
      allow read, write: if false; // System internal
    }

    match /documents/{docId} {
      allow read: if isAuth() && matchesScope(resource.data);
      allow create: if isAuth() && matchesScope(request.resource.data);
      allow update: if isAuth() 
                    && matchesScope(resource.data) 
                    && matchesScope(request.resource.data)
                    && resource.data.status != 'posted'; 
      allow delete: if false;
    }

    match /audit_logs/{logId} {
      allow read: if isAuth() && matchesScope(resource.data);
      allow create: if isAuth() && matchesScope(request.resource.data);
      allow update, delete: if false; 
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
