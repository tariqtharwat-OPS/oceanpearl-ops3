/**
 * Upload and extract document
 */
exports.sharkUploadAndExtract = onCall(async (request) => {
  const user = await authenticateUser(request);
  const { fileUrl, fileName, mimeType } = request.data;

  // TODO: Implement Gemini 2.0 Flash extraction
  // For now, return a placeholder

  const suggestionRef = db.collection("shark_suggestions").doc();
  const suggestionData = {
    userId: user.uid,
    status: "DRAFT",
    sourceFileName: fileName,
    extractedFields: {},
    proposedPayload: {},
    createdTs: admin.firestore.FieldValue.serverTimestamp(),
  };

  await suggestionRef.set(suggestionData);

  return { success: true, suggestionId: suggestionRef.id };
});

/**
 * Get user suggestions
 */
exports.sharkGetSuggestions = onCall(async (request) => {
  const user = await authenticateUser(request);

  let query = db.collection("shark_suggestions");

  // Non-CEO users can only see their own suggestions
  if (user.role !== "CEO") {
    query = query.where("userId", "==", user.uid);
  }

  const snapshot = await query.orderBy("createdTs", "desc").limit(50).get();
  const suggestions = [];

  snapshot.forEach((doc) => {
    suggestions.push({ id: doc.id, ...doc.data() });
  });

  return { suggestions };
});

/**
 * Update suggestion status
 */
exports.sharkUpdateSuggestion = onCall(async (request) => {
  const user = await authenticateUser(request);
  const { suggestionId, status } = request.data;

  const suggestionDoc = await db.collection("shark_suggestions").doc(suggestionId).get();
  if (!suggestionDoc.exists) {
    throw new HttpsError("not-found", "Suggestion not found");
  }

  const suggestion = suggestionDoc.data();

  // Verify ownership or CEO
  if (suggestion.userId !== user.uid && user.role !== "CEO") {
    throw new HttpsError("permission-denied", "Access denied");
  }

  await db.collection("shark_suggestions").doc(suggestionId).update({
    status,
    updatedTs: admin.firestore.FieldValue.serverTimestamp(),
  });

  return { success: true };
});

