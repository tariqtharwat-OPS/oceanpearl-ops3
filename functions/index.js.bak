/**
 * Update user access
 */
exports.updateUserAccess = onCall(async (request) => {
  const user = await authenticateUser(request);
  if (!hasRole(user, ["CEO"])) {
    throw new HttpsError("permission-denied", "Only CEO can update user access");
  }

  const { userId, role, allowedLocations, allowedUnits, displayName, companyEmail } = request.data;

  if (!userId) {
    throw new HttpsError("invalid-argument", "Missing userId");
  }

  const updates = {};
  if (role) updates.role = role;
  if (allowedLocations) updates.allowedLocations = allowedLocations;
  if (allowedUnits) updates.allowedUnits = allowedUnits;
  if (displayName) updates.displayName = displayName;
  if (companyEmail) updates.companyEmail = companyEmail;
  updates.updatedAt = admin.firestore.FieldValue.serverTimestamp();

  await db.collection("users").doc(userId).update(updates);
  await logAudit(user.uid, "UPDATE", "user", userId, updates);

  return { success: true };
});

