const { onRequest, onCall, HttpsError } = require("firebase-functions/v2/https");
const { setGlobalOptions } = require("firebase-functions/v2");
const admin = require("firebase-admin");

// Set region to asia-southeast1 as per user preference
setGlobalOptions({ region: "asia-southeast1" });

admin.initializeApp();
const db = admin.firestore();

// ============================================================================
// HELPER FUNCTIONS
// ============================================================================

/**
 * Verify user authentication and get user data
 */
async function authenticateUser(context) {
  if (!context.auth) {
    throw new HttpsError("unauthenticated", "User must be authenticated");
  }

  const userId = context.auth.uid;
  const userDoc = await db.collection("users").doc(userId).get();

  if (!userDoc.exists) {
    // Create user document if it doesn't exist
    const userData = {
      displayName: context.auth.token.name || "",
      email: context.auth.token.email || "",
      role: "user",
      allowedLocations: [],
      allowedUnits: [],
      createdAt: admin.firestore.FieldValue.serverTimestamp(),
    };
    await db.collection("users").doc(userId).set(userData);
    return { uid: userId, ...userData };
  }

  return { uid: userId, ...userDoc.data() };
}

/**
 * Check if user has required role
 */
function hasRole(user, allowedRoles) {
  return allowedRoles.includes(user.role) || user.role === "CEO";
}

/**
 * Generate idempotency key and check if operation already executed
 */
async function checkIdempotency(operationId) {
  if (!operationId) return null;

  const keyDoc = await db.collection("idempotency_keys").doc(operationId).get();
  if (keyDoc.exists) {
    return keyDoc.data().result;
  }
  return null;
}

/**
 * Store idempotency result
 */
async function storeIdempotency(operationId, result) {
  if (!operationId) return;

  await db.collection("idempotency_keys").doc(operationId).set({
    createdAt: admin.firestore.FieldValue.serverTimestamp(),
    result: result,
  });
}

/**
 * Log audit entry
 */
async function logAudit(userId, action, entityType, entityId, changes) {
  await db.collection("audit_logs").add({
    ts: admin.firestore.FieldValue.serverTimestamp(),
    userId,
    action,
    entityType,
    entityId,
    changes: changes || {},
  });
}

// ============================================================================
// ADMIN OPERATIONS
