/**
 * Create location
 */
exports.createLocation = onCall(async (request) => {
  const user = await authenticateUser(request);
  if (!hasRole(user, ["CEO", "HQ_FINANCE"])) {
    throw new HttpsError("permission-denied", "Only CEO or HQ Finance can create locations");
  }

  const { locationId, name, type } = request.data;

  if (!locationId || !name || !type) {
    throw new HttpsError("invalid-argument", "Missing required fields");
  }

  const locationData = {
    name,
    type,
    active: true,
    createdAt: admin.firestore.FieldValue.serverTimestamp(),
  };

  await db.collection("locations").doc(locationId).set(locationData);
  await logAudit(user.uid, "CREATE", "location", locationId, locationData);

  return { success: true, locationId };
});

/**
 * List locations
 */
exports.listLocations = onCall(async (request) => {
  const user = await authenticateUser(request);

  const snapshot = await db.collection("locations").where("active", "==", true).get();
  const locations = [];

  snapshot.forEach((doc) => {
    locations.push({ id: doc.id, ...doc.data() });
  });

  return { locations };
});

/**
 * Create unit
 */
exports.createUnit = onCall(async (request) => {
  const user = await authenticateUser(request);
  if (!hasRole(user, ["CEO", "HQ_FINANCE"])) {
    throw new HttpsError("permission-denied", "Only CEO or HQ Finance can create units");
  }

  const { id, locationId, name, unitType, active } = request.data;

  if (!id || !locationId || !name || !unitType) {
    throw new HttpsError("invalid-argument", "Missing required fields: id, locationId, name, unitType");
  }

  // Validate location exists
  const locationDoc = await db.collection("locations").doc(locationId).get();
  if (!locationDoc.exists) {
    throw new HttpsError("invalid-argument", "Invalid locationId: location does not exist");
  }

  const unitData = {
    locationId,
    name,
    unitType,
    active: active !== undefined ? active : true,
    createdTs: admin.firestore.FieldValue.serverTimestamp(),
  };

  await db.collection("units").doc(id).set(unitData);
  await logAudit(user.uid, "CREATE", "unit", id, unitData);

  return { success: true, unitId: id };
});

/**
 * Update unit
 */
exports.updateUnit = onCall(async (request) => {
  const user = await authenticateUser(request);
  if (!hasRole(user, ["CEO", "HQ_FINANCE"])) {
    throw new HttpsError("permission-denied", "Only CEO or HQ Finance can update units");
  }

  const { id, locationId, name, unitType, active } = request.data;

  if (!id) {
    throw new HttpsError("invalid-argument", "Missing required field: id");
  }

  // Validate location exists if locationId is being updated
  if (locationId) {
    const locationDoc = await db.collection("locations").doc(locationId).get();
    if (!locationDoc.exists) {
      throw new HttpsError("invalid-argument", "Invalid locationId: location does not exist");
    }
  }

  const updates = {};
  if (locationId !== undefined) updates.locationId = locationId;
  if (name !== undefined) updates.name = name;
  if (unitType !== undefined) updates.unitType = unitType;
  if (active !== undefined) updates.active = active;
  updates.updatedTs = admin.firestore.FieldValue.serverTimestamp();

  await db.collection("units").doc(id).update(updates);
  await logAudit(user.uid, "UPDATE", "unit", id, updates);

  return { success: true, unitId: id };
});

/**
 * List units
 */
exports.listUnits = onCall(async (request) => {
  const user = await authenticateUser(request);
  const { locationId } = request.data || {};

  let query = db.collection("units").where("active", "==", true);

  if (locationId) {
    query = query.where("locationId", "==", locationId);
  }

  const snapshot = await query.get();
  const units = [];

  snapshot.forEach((doc) => {
    const unitData = doc.data();
    // Filter based on user permissions
    if (hasRole(user, ["CEO", "HQ_FINANCE"])) {
      // Admin/CEO can see all units
      units.push({ id: doc.id, ...unitData });
    } else if (user.allowedUnits && user.allowedUnits.includes(doc.id)) {
      // User can see units in their allowedUnits
      units.push({ id: doc.id, ...unitData });
    } else if (user.allowedLocations && user.allowedLocations.includes(unitData.locationId)) {
      // User can see units in their allowedLocations
      units.push({ id: doc.id, ...unitData });
    }
  });

  return { units };
});

