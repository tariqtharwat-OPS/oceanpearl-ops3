/**
 * Main API endpoint
 */
exports.api = onRequest({ cors: true }, async (req, res) => {
  res.json({
    status: "ok",
    message: "Ocean Pearl OPS V2 API",
    version: "1.0.0",
  });
});

/**
 * Record sale
 */
exports.recordSale = onCall(async (request) => {
  const user = await authenticateUser(request);
  const { saleId, lotIds, customerName, pricePerKg, currency, quantityKg, unitId } = request.data;

  if (!saleId || !lotIds || !customerName || !pricePerKg || !currency || !quantityKg || !unitId) {
    throw new HttpsError("invalid-argument", "Missing required fields");
  }

  const batch = db.batch();

  // 1. Create Sale Record
  const saleRef = db.collection("sales").doc(saleId);
  const saleData = {
    lotIds,
    customerName,
    pricePerKg,
    currency,
    quantityKg,
    totalAmount: pricePerKg * quantityKg,
    createdBy: user.uid,
    createdAt: admin.firestore.FieldValue.serverTimestamp(),
  };
  batch.set(saleRef, saleData);

  // 2. Create Ledger Entry (Revenue)
  const ledgerRef = db.collection("ledger_entries").doc();
  const ledgerData = {
    ts: admin.firestore.FieldValue.serverTimestamp(),
    fromWalletId: `customer_${customerName.replace(/\s+/g, '_').toLowerCase()}`, // Customer pays
    toWalletId: `unit_${unitId}_cash`, // Unit receives cash
    amount: saleData.totalAmount,
    currency,
    fxRate: 1.0,
    amountBase: saleData.totalAmount,
    operationType: "SALE",
    operationId: saleId,
    description: `Sale to ${customerName}`,
  };
  batch.set(ledgerRef, ledgerData);

  // 3. Consume Inventory Lots (Atomic consistency)
  for (const lotId of lotIds) {
    const lotRef = db.collection("inventory_lots").doc(lotId);
    batch.update(lotRef, {
      status: "SOLD",
      saleId: saleId,
      updatedAt: admin.firestore.FieldValue.serverTimestamp()
    });
  }

  await batch.commit();
  await logAudit(user.uid, "CREATE", "sale", saleId, saleData);

  return { success: true, saleId };
});

/**
 * Record payment
 */
exports.recordPayment = onCall(async (request) => {
  const user = await authenticateUser(request);
  const { paymentId, unitId, amount, currency, type, description } = request.data;

  if (!paymentId || !unitId || !amount || !currency || !type) {
    throw new HttpsError("invalid-argument", "Missing required fields");
  }

  const batch = db.batch();

  // 1. Create Payment Record
  const paymentRef = db.collection("payments").doc(paymentId);
  const paymentData = {
    unitId,
    amount,
    currency,
    type,
    description,
    createdBy: user.uid,
    createdAt: admin.firestore.FieldValue.serverTimestamp(),
  };
  batch.set(paymentRef, paymentData);

  // 2. Create Ledger Entry
  const ledgerRef = db.collection("ledger_entries").doc();

  let fromWalletId, toWalletId;

  if (type === "payment") {
    // Outgoing payment
    fromWalletId = `unit_${unitId}_cash`;
    toWalletId = "external_party";
  } else {
    // Incoming payment (collection)
    fromWalletId = "external_party";
    toWalletId = `unit_${unitId}_cash`;
  }

  const ledgerData = {
    ts: admin.firestore.FieldValue.serverTimestamp(),
    fromWalletId,
    toWalletId,
    amount,
    currency,
    fxRate: 1.0,
    amountBase: amount,
    operationType: type.toUpperCase(),
    operationId: paymentId,
    description: description || `${type} for unit ${unitId}`,
  };
  batch.set(ledgerRef, ledgerData);

  await batch.commit();
  await logAudit(user.uid, "CREATE", "payment", paymentId, paymentData);

  return { success: true, paymentId };
});

/**
 * Create test users (HTTP endpoint for admin use)
 */
exports.createTestUsers = onRequest({ cors: true }, async (req, res) => {
  const testUsers = [
    { email: 'ceo@oceanpearlseafood.com', password: 'OceanPearl2026!', role: 'CEO', displayName: 'CEO' },
    { email: 'finance@oceanpearlseafood.com', password: 'OceanPearl2026!', role: 'HQ_FINANCE', displayName: 'Finance Manager' },
    { email: 'manager.kaimana@oceanpearlseafood.com', password: 'OceanPearl2026!', role: 'LOCATION_MANAGER', displayName: 'Kaimana Manager' },
    { email: 'operator.boat1@oceanpearlseafood.com', password: 'OceanPearl2026!', role: 'OPERATOR', displayName: 'Boat 1 Operator' },
    { email: 'investor@oceanpearlseafood.com', password: 'OceanPearl2026!', role: 'INVESTOR', displayName: 'Investor' }
  ];

  const results = [];

  for (const userData of testUsers) {
    try {
      const userRecord = await admin.auth().createUser({
        email: userData.email,
        password: userData.password,
        displayName: userData.displayName
      });

      await db.collection('users').doc(userRecord.uid).set({
        email: userData.email,
        displayName: userData.displayName,
        role: userData.role,
        companyEmail: userData.email,
        allowedLocations: [],
        allowedUnits: [],
        createdAt: admin.firestore.FieldValue.serverTimestamp()
      });

      results.push({ success: true, email: userData.email, uid: userRecord.uid });
    } catch (error) {
      if (error.code === 'auth/email-already-exists') {
        results.push({ success: false, email: userData.email, error: 'Already exists' });
      } else {
        results.push({ success: false, email: userData.email, error: error.message });
      }
    }
  }

  res.json({
    message: 'Test users creation completed',
    password: 'OceanPearl2026!',
    results
  });
});



