// ============================================================================
// OPERATIONAL WORKFLOWS
// ============================================================================

/**
 * Receive lot (create inventory + ledger entry)
 */
exports.receiveLot = onCall(async (request) => {
  const user = await authenticateUser(request);
  const { operationId, unitId, productSpecId, quantityKg, pricePerKg, currency, supplierId } = request.data;

  // Check idempotency
  const existing = await checkIdempotency(operationId);
  if (existing) return existing;

  // Verify user has access to unit
  if (user.role === "UNIT_OP" && !user.allowedUnits.includes(unitId)) {
    throw new HttpsError("permission-denied", "User does not have access to this unit");
  }

  const batch = db.batch();

  // Create inventory lot
  const lotRef = db.collection("inventory_lots").doc();
  const lotData = {
    unitId,
    productSpecId,
    quantityKg,
    status: "IN_STOCK",
    createdTs: admin.firestore.FieldValue.serverTimestamp(),
  };
  batch.set(lotRef, lotData);

  // Create ledger entry (payment to supplier)
  const ledgerRef = db.collection("ledger_entries").doc();
  const ledgerData = {
    ts: admin.firestore.FieldValue.serverTimestamp(),
    fromWalletId: `unit_${unitId}_cash`,
    toWalletId: `supplier_${supplierId}`,
    amount: pricePerKg * quantityKg,
    currency,
    fxRate: 1.0,
    amountBase: pricePerKg * quantityKg,
    operationType: "RECEIVE",
    operationId: lotRef.id,
    description: `Receive ${quantityKg}kg from supplier ${supplierId}`,
  };
  batch.set(ledgerRef, ledgerData);

  await batch.commit();

  const result = { success: true, lotId: lotRef.id, ledgerEntryId: ledgerRef.id };
  await storeIdempotency(operationId, result);
  await logAudit(user.uid, "RECEIVE", "inventory_lot", lotRef.id, lotData);

  return result;
});

/**
 * Transfer lot between units
 */
exports.transferLot = onCall(async (request) => {
  const user = await authenticateUser(request);
  const { operationId, lotId, fromUnitId, toUnitId, quantityKg } = request.data;

  // Check idempotency
  const existing = await checkIdempotency(operationId);
  if (existing) return existing;

  // Verify access
  if (user.role === "UNIT_OP" && !user.allowedUnits.includes(fromUnitId)) {
    throw new HttpsError("permission-denied", "User does not have access to source unit");
  }

  const batch = db.batch();

  // Get source lot
  const lotDoc = await db.collection("inventory_lots").doc(lotId).get();
  if (!lotDoc.exists) {
    throw new HttpsError("not-found", "Lot not found");
  }

  const lotData = lotDoc.data();

  // Update source lot quantity
  const newQuantity = lotData.quantityKg - quantityKg;
  if (newQuantity < 0) {
    throw new HttpsError("invalid-argument", "Insufficient quantity");
  }

  if (newQuantity === 0) {
    batch.update(db.collection("inventory_lots").doc(lotId), {
      status: "TRANSFERRED",
      quantityKg: 0,
    });
  } else {
    batch.update(db.collection("inventory_lots").doc(lotId), {
      quantityKg: newQuantity,
    });
  }

  // Create new lot at destination
  const newLotRef = db.collection("inventory_lots").doc();
  const newLotData = {
    unitId: toUnitId,
    productSpecId: lotData.productSpecId,
    quantityKg,
    status: "IN_STOCK",
    createdTs: admin.firestore.FieldValue.serverTimestamp(),
  };
  batch.set(newLotRef, newLotData);

  await batch.commit();

  const result = { success: true, newLotId: newLotRef.id };
  await storeIdempotency(operationId, result);
  await logAudit(user.uid, "TRANSFER", "inventory_lot", lotId, { fromUnitId, toUnitId, quantityKg });

  return result;
});

/**
 * Production (transform input lots into output lots)
 */
exports.productionTransform = onCall(async (request) => {
  const user = await authenticateUser(request);
  const { operationId, unitId, inputLots, outputLots, wasteLots } = request.data;

  // Check idempotency
  const existing = await checkIdempotency(operationId);
  if (existing) return existing;

  // Verify access
  if (user.role === "UNIT_OP" && !user.allowedUnits.includes(unitId)) {
    throw new HttpsError("permission-denied", "User does not have access to this unit");
  }

  const batch = db.batch();

  // Invariant 2: Mass Conservation
  const totalInput = inputLots.reduce((acc, lot) => acc + Number(lot.quantityKg || 0), 0);
  const totalOutput = outputLots.reduce((acc, lot) => acc + Number(lot.quantityKg || 0), 0);
  const totalWaste = (wasteLots || []).reduce((acc, lot) => acc + Number(lot.quantityKg || 0), 0);

  // Allow minimal floating point error (e.g. 0.001 kg)
  if (Math.abs(totalInput - (totalOutput + totalWaste)) > 0.001) {
    throw new HttpsError(
      "invalid-argument",
      `Mass conservation violation: Input(${totalInput}) != Output(${totalOutput}) + Waste(${totalWaste})`
    );
  }

  // Consume input lots
  for (const input of inputLots) {
    batch.update(db.collection("inventory_lots").doc(input.lotId), {
      status: "CONSUMED",
      quantityKg: 0,
    });
  }

  // Create output lots
  const outputLotIds = [];
  for (const output of outputLots) {
    const outputLotRef = db.collection("inventory_lots").doc();
    batch.set(outputLotRef, {
      unitId,
      productSpecId: output.productSpecId,
      quantityKg: output.quantityKg,
      status: "IN_STOCK",
      createdTs: admin.firestore.FieldValue.serverTimestamp(),
    });
    outputLotIds.push(outputLotRef.id);
  }

  // Create waste lots if any
  const wasteLotIds = [];
  if (wasteLots && wasteLots.length > 0) {
    for (const waste of wasteLots) {
      const wasteLotRef = db.collection("inventory_lots").doc();
      batch.set(wasteLotRef, {
        unitId,
        productSpecId: waste.productSpecId,
        quantityKg: waste.quantityKg,
        status: "WASTE",
        createdTs: admin.firestore.FieldValue.serverTimestamp(),
      });
      wasteLotIds.push(wasteLotRef.id);
    }
  }

  await batch.commit();

  const result = { success: true, outputLotIds, wasteLotIds };
  await storeIdempotency(operationId, result);
  await logAudit(user.uid, "PRODUCTION", "inventory_lot", operationId, { inputLots, outputLots, wasteLots });

  return result;
});

/**
 * Get inventory by unit
 */
exports.getInventoryByUnit = onCall(async (request) => {
  const user = await authenticateUser(request);
  const { unitId } = request.data;

  // Verify access
  if (user.role === "UNIT_OP" && !user.allowedUnits.includes(unitId)) {
    throw new HttpsError("permission-denied", "User does not have access to this unit");
  }

  const snapshot = await db.collection("inventory_lots")
    .where("unitId", "==", unitId)
    .where("status", "==", "IN_STOCK")
    .get();

  const lots = [];
  snapshot.forEach((doc) => {
    lots.push({ id: doc.id, ...doc.data() });
  });

  return { lots };
});

// ============================================================================
// FINANCE OPERATIONS
// ============================================================================

/**
 * Get trial balance
 */
exports.getTrialBalance = onCall(async (request) => {
  const user = await authenticateUser(request);
  if (!hasRole(user, ["CEO", "HQ_FINANCE", "INVESTOR_READONLY"])) {
    throw new HttpsError("permission-denied", "Access denied");
  }

  // Guard against legacy ledger collection
  const legacySnapshot = await db.collection("ledger").limit(1).get();
  if (!legacySnapshot.empty) {
    throw new HttpsError("failed-precondition", "Invalid ledger collection detected. Use ledger_entries only.");
  }

  const snapshot = await db.collection("ledger_entries").get();
  const walletBalances = {};

  snapshot.forEach((doc) => {
    const entry = doc.data();
    const amount = entry.amountBase || entry.amount;

    // Debit (from wallet)
    if (entry.fromWalletId) {
      if (!walletBalances[entry.fromWalletId]) {
        walletBalances[entry.fromWalletId] = 0;
      }
      walletBalances[entry.fromWalletId] -= amount;
    }

    // Credit (to wallet)
    if (entry.toWalletId) {
      if (!walletBalances[entry.toWalletId]) {
        walletBalances[entry.toWalletId] = 0;
      }
      walletBalances[entry.toWalletId] += amount;
    }
  });

  const balances = Object.entries(walletBalances).map(([walletId, balance]) => ({
    walletId,
    balance,
  }));

  return { balances };
});

/**
 * Get P&L by unit
 */
exports.getPLByUnit = onCall(async (request) => {
  const user = await authenticateUser(request);
  if (!hasRole(user, ["CEO", "HQ_FINANCE", "LOC_MANAGER", "INVESTOR_READONLY"])) {
    throw new HttpsError("permission-denied", "Access denied");
  }

  const { unitId } = request.data;

  // Get all ledger entries for this unit's wallet
  const snapshot = await db.collection("ledger_entries")
    .where("fromWalletId", "==", `unit_${unitId}_cash`)
    .get();

  let totalExpenses = 0;
  let totalRevenue = 0;

  snapshot.forEach((doc) => {
    const entry = doc.data();
    const amount = entry.amountBase || entry.amount;

    if (entry.operationType === "RECEIVE" || entry.operationType === "PRODUCTION") {
      totalExpenses += amount;
    } else if (entry.operationType === "SALE") {
      totalRevenue += amount;
    }
  });

  return {
    unitId,
    totalRevenue,
    totalExpenses,
    netProfit: totalRevenue - totalExpenses,
  };
});

